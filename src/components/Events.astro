---
import { supabase } from '../lib/supabase';
import EventCard    from './EventCard.astro';
import type { Campaign } from '../lib/types';

// ── Same title → campaign mapping as the events page ──────────────────────
const titleToCampaign: Record<string, Campaign> = {
	'Gåtur':                    'det-okay',
	'Løb med Headspace':        'diy',
	'Foredrag med influencer':  'diy',
	'Brætspilscafe':            'brave-together',
	'Koncert med musiker':      'brave-together',
	'Headspace LAN event':      'diy',
	'Intimkoncert med musiker': 'brave-together',
};

function getDanishDay(dateStr: string): string {
	const [year, month, day] = dateStr.split('-').map(Number);
	const name = new Date(year, month - 1, day).toLocaleDateString('da-DK', { weekday: 'long' });
	return name.charAt(0).toUpperCase() + name.slice(1);
}

function formatTime(timeStr: string): string {
	return 'kl. ' + timeStr.slice(0, 5).replace(':', '.');
}

// ── Fetch all events, then pick 3 at random ───────────────────────────────
const { data: rows } = await supabase.from('headspace').select('*');

const all = (rows ?? []).map(row => ({
	id:       row.id       as number,
	title:    row.titel    as string,
	time:     `${getDanishDay(row.dato as string)} ${formatTime(row.tid as string)}`,
	location: row.sted     as string,
	campaign: (titleToCampaign[row.titel as string] ?? 'det-okay') as Campaign,
}));

// Shuffle and take the first 3
const featured = all
	.sort(() => Math.random() - 0.5)
	.slice(0, 3);
---

<section class="events">
	<div class="container">

		<h2>EVENTS</h2>
		<p class="subtitle">
			Vi holder løbende events og kampagner for unge i hele Danmark. Kom med og vær en del af
			fællesskabet og hjælp os med at gøre en forskel.
		</p>

		<div class="cards">
			{featured.map(event => (
				<EventCard
					title={event.title}
					time={event.time}
					location={event.location}
					campaign={event.campaign}
					href={`/tilmelding?id=${event.id}`}
				/>
			))}
		</div>

		<div class="actions">
			<a href="/events" class="btn btn-outline">se alle vores kommende events</a>
			<a href="/tilmelding" class="btn btn-green">lav et event</a>
		</div>

	</div>
</section>

<style>
	.events {
		background: var(--blue);
		padding: 60px 32px;
	}

	.container {
		max-width: 960px;
		margin: 0 auto;
		text-align: center;
	}

	h2 {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 2rem;
		color: var(--purple);
		margin: 0 0 16px;
		letter-spacing: 0.02em;
	}

	.subtitle {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text);
		max-width: 600px;
		margin: 0 auto 40px;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin-bottom: 36px;
		text-align: left;
	}

	.actions {
		display: flex;
		justify-content: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		padding: 12px 28px;
		border-radius: 999px;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.9rem;
		transition: opacity 0.2s;
	}

	.btn:hover { opacity: 0.85; }

	.btn-outline {
		background: transparent;
		border: 2px solid var(--text);
		color: var(--text);
	}

	.btn-green {
		background: var(--green);
		color: white;
	}

	@media (max-width: 768px) {
		.cards { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 480px) {
		.cards { grid-template-columns: 1fr; }
	}
</style>
