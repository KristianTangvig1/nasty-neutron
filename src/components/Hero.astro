---

<section class="hero">
	<span class="photo-credit">photo credit</span>
	<div class="hero-text">
		<h1 class="hero-title">HEADSPACE</h1>
		<p class="hero-subtitle">Nogen At Tale Med</p>
	</div>
</section>

<style>
	.hero {
		position: relative;
		width: 100%;
		min-height: 480px;
		background-color: var(--green);
		background-image:
			radial-gradient(ellipse at 30% 60%, rgba(56,181,85,0.4) 0%, transparent 60%),
			radial-gradient(ellipse at 70% 30%, rgba(120,186,83,0.3) 0%, transparent 50%);
		display: flex;
		align-items: flex-end;
		overflow: hidden;
	}

	.photo-credit {
		position: absolute;
		top: 16px;
		left: 20px;
		font-family: 'Agrandir', sans-serif;
		font-size: 0.7rem;
		color: rgba(255,255,255,0.7);
		letter-spacing: 0.05em;
		text-transform: lowercase;
	}

	.hero-text {
		padding: 0 32px 40px;
	}

	.hero-title {
		font-family: 'Gasoek One', sans-serif;
		font-size: clamp(3rem, 10vw, 7rem);
		font-weight: 400;
		line-height: 0.95;
		margin: 0 0 8px;
		color: transparent;
		-webkit-text-stroke: 3px #ffffff;
		text-stroke: 3px #ffffff;
		letter-spacing: -0.01em;
	}

	.hero-subtitle {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		color: var(--lavender);
		margin: 0;
		letter-spacing: -0.01em;
	}
</style>
