---

---

<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline>
    <source src="/video/Herovid.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>

  <div class="hero-text">
    <h1 class="hero-title">HEADSPACE</h1>
    <p class="hero-subtitle">Nogen At Tale Med</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(50, 100, 30, 0.52);
    z-index: 1;
  }

  .hero-text {
    position: relative;
    z-index: 2;
    padding: 0 32px 48px;
  }

  .hero-title {
    font-family: "Gasoek One", sans-serif;
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 400;
    line-height: 0.95;
    margin: 0 0 8px;
    color: white;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-family: "Agrandir", sans-serif;
    font-weight: 900;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--lavender);
    margin: 0;
    letter-spacing: -0.01em;
  }
</style>
