<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline>
    <source src="/video/Herovid.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>

  <h1>Headspace<br />Hvem er vi?</h1>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: 48px 32px;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(50, 100, 30, 0.52);
    z-index: 1;
  }

  h1 {
    position: relative;
    z-index: 2;
    font-family: "Gasoek One", sans-serif;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 400;
    line-height: 1.05;
    margin: 0;
    color: white;
    letter-spacing: -0.01em;
  }
</style>
