<style>
  footer {
    background: var(--green);
    padding: 48px 32px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
  }

  .logo {
    font-family: "VAG Rounded", "Nunito", sans-serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: white;
    display: block;
    margin-bottom: 20px;
  }

  address {
    font-style: normal;
  }

  address p {
    font-family: "Agrandir", sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: white;
    margin: 0 0 4px;
    line-height: 1.5;
  }

  address a {
    color: white;
    text-decoration: underline;
  }

  .hours {
    margin-top: 8px !important;
    opacity: 0.85;
  }

  .socials {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 4px;
  }

  .socials a {
    color: white;
    transition: opacity 0.2s;
  }

  .socials a:hover {
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .container {
      flex-direction: column;
    }
    .socials {
      flex-direction: row;
    }
  }
</style>
