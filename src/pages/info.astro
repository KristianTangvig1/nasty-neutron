---
import Layout      from '../layouts/Layout.astro';
import SoMe        from '../components/SoMe.astro';
---

<Layout title="Om Os — headspace Danmark">

	<!-- ── Hero ── -->
	<section class="hero">
		<h1>Headspace<br/>Hvem er vi?</h1>
	</section>

	<!-- ── Om Os content ── -->
	<section class="about">
		<div class="about-inner">

			<!-- Row 1: visual block left, intro text right -->
			<div class="row row-top">

				<div class="visual-block green-block">
					<span class="vb-eyebrow">siden 2010</span>
					<span class="vb-title">OM<br/>HEAD<br/>SPACE</span>
					<span class="vb-tag">Nogen at tale med</span>
				</div>

				<p class="intro-text">
					Headspace Events er en organisation, der skaber meningsfulde arrangementer
					for unge med fokus på mental trivsel, fællesskab og personlig udvikling.
					Gennem events, workshops og sociale aktiviteter giver Headspace Events unge
					mulighed for at mødes i trygge rammer, hvor der er plads til både samtaler,
					nye relationer og fælles oplevelser.
				</p>

			</div>

			<!-- Row 2: body text left, visual block right -->
			<div class="row row-bottom">

				<div class="body-text">
					<p>
						Formålet med aktiviteterne er at styrke unges mentale sundhed ved at
						skabe fællesskaber, hvor ingen behøver at stå alene med deres
						udfordringer.
					</p>
					<p>
						Eventsene giver deltagerne mulighed for at dele erfaringer, få nye
						perspektiver og opleve, at det er helt normalt at tale om både glæder
						og bekymringer.
					</p>
					<p>
						Headspace Events arbejder ud fra en tro på, at stærke fællesskaber kan
						være med til at forebygge ensomhed og mistrivsel blandt unge.
					</p>
				</div>

				<div class="visual-block purple-block">
					<span class="vb-quote">&ldquo;</span>
					<span class="vb-quote-text">Stærke fællesskaber forebygger ensomhed og mistrivsel blandt unge.</span>
					<span class="vb-tag light">— headspace Danmark</span>
				</div>

			</div>

		</div>
	</section>

	<!-- ── Social media ── -->
	<SoMe />

</Layout>

<style>
	/* ── Hero ── */
	.hero {
		width: 100%;
		min-height: 360px;
		background: linear-gradient(160deg, #a8d88a 0%, #78BA53 50%, #4a7c32 100%);
		display: flex;
		align-items: flex-end;
		padding: 48px 32px;
	}

	.hero h1 {
		font-family: 'Gasoek One', sans-serif;
		font-size: clamp(2.5rem, 8vw, 5rem);
		font-weight: 400;
		line-height: 1.05;
		margin: 0;
		color: transparent;
		-webkit-text-stroke: 3px white;
		letter-spacing: -0.01em;
	}

	/* ── About section ── */
	.about {
		background: #d4edbb;
		padding: 64px 32px;
	}

	.about-inner {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 48px;
	}

	.row {
		display: grid;
		gap: 36px;
		align-items: center;
	}

	.row-top    { grid-template-columns: 1fr 1fr; }
	.row-bottom { grid-template-columns: 3fr 2fr; }

	/* ── Visual blocks (replace missing photos) ── */
	.visual-block {
		border-radius: 20px;
		padding: 36px 32px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 280px;
	}

	.green-block  { background: var(--green); }
	.purple-block { background: var(--purple); }

	.vb-eyebrow {
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.75);
	}

	.vb-title {
		font-family: 'Gasoek One', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 0.95;
		color: transparent;
		-webkit-text-stroke: 2px white;
		letter-spacing: -0.01em;
	}

	.vb-tag {
		display: inline-block;
		align-self: flex-start;
		background: rgba(255,255,255,0.2);
		border: 1.5px solid rgba(255,255,255,0.5);
		border-radius: 999px;
		padding: 6px 16px;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.78rem;
		color: white;
	}

	.vb-quote {
		font-family: 'Gasoek One', sans-serif;
		font-size: 5rem;
		line-height: 0.8;
		color: rgba(255,255,255,0.35);
	}

	.vb-quote-text {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 1.05rem;
		line-height: 1.5;
		color: white;
		flex: 1;
		padding: 8px 0;
	}

	.vb-tag.light {
		background: rgba(255,255,255,0.15);
		border-color: rgba(255,255,255,0.35);
	}

	/* ── Text columns ── */
	.intro-text {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 0.95rem;
		line-height: 1.8;
		color: var(--text);
		margin: 0;
	}

	.body-text {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.body-text p {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 0.95rem;
		line-height: 1.8;
		color: var(--text);
		margin: 0;
	}

	/* ── Responsive ── */
	@media (max-width: 680px) {
		.row-top,
		.row-bottom { grid-template-columns: 1fr; }

		.row-bottom .visual-block { order: -1; }
	}
</style>
