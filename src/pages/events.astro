---
import Layout        from '../layouts/Layout.astro';
import { supabase }  from '../lib/supabase';
import type { Campaign, EventItem } from '../lib/types';

import EventsHero      from '../components/events/EventsHero.astro';
import EventsIntro     from '../components/events/EventsIntro.astro';
import EventFilterBar  from '../components/events/EventFilterBar.astro';
import EventsGrid      from '../components/events/EventsGrid.astro';

// ── Helpers ──────────────────────────────────────────────────────────────────

const titleToCampaign: Record<string, Campaign> = {
	'Gåtur':                    'det-okay',
	'Løb med Headspace':        'diy',
	'Foredrag med influencer':  'diy',
	'Brætspilscafe':            'brave-together',
	'Koncert med musiker':      'brave-together',
	'Headspace LAN event':      'diy',
	'Intimkoncert med musiker': 'brave-together',
};

function getDanishDay(dateStr: string): string {
	const [year, month, day] = dateStr.split('-').map(Number);
	const name = new Date(year, month - 1, day).toLocaleDateString('da-DK', { weekday: 'long' });
	return name.charAt(0).toUpperCase() + name.slice(1);
}

function formatTime(timeStr: string): string {
	return 'kl. ' + timeStr.slice(0, 5).replace(':', '.');
}

// ── Data fetching ─────────────────────────────────────────────────────────────

const { data: rows, error } = await supabase
	.from('headspace')
	.select('*')
	.order('dato', { ascending: true })
	.order('tid',  { ascending: true });

if (error) console.error('Supabase fejl:', error.message);

// ── Transform rows to EventItem objects ───────────────────────────────────────

const events: EventItem[] = (rows ?? []).map(row => ({
	id:          row.id          as number,
	title:       row.titel       as string,
	beskrivelse: row.beskrivelse as string,
	day:         getDanishDay(row.dato as string),
	time:        `${getDanishDay(row.dato as string)} ${formatTime(row.tid as string)}`,
	location:    row.sted        as string,
	campaign:    (titleToCampaign[row.titel as string] ?? 'det-okay') as Campaign,
}));

// ── Derived filter data ───────────────────────────────────────────────────────

const allDays   = ['Mandag', 'Tirsdag', 'Onsdag', 'Torsdag', 'Fredag', 'Lørdag', 'Søndag'];
const eventDays = new Set(events.map(e => e.day));
const days      = allDays.filter(d => eventDays.has(d));

const locations = [...new Set(events.map(e => e.location))].sort();
---

<Layout title="Events — headspace Danmark">

	<EventsHero />

	<EventsIntro />

	<section class="calendar-section">
		<EventFilterBar days={days} locations={locations} />
		<EventsGrid events={events} />
	</section>

</Layout>

<!-- Filtering logic — runs client-side, orchestrates EventFilterBar + EventsGrid -->
<script>
	let activeDay:      string | null = null;
	let activeLocation: string | null = null;

	const cards      = Array.from(document.querySelectorAll<HTMLElement>('.card-wrapper'));
	const emptyState = document.getElementById('empty-state')!;
	const activeBar  = document.getElementById('active-filters')!;
	const filterText = document.getElementById('filter-text')!;
	const clearBtn   = document.getElementById('clear-filters')!;
	const dagGroup   = document.getElementById('dag-group')!;
	const omradeGroup = document.getElementById('omrade-group')!;

	// ── Apply current filters to the card grid ────────────────────────────────
	function applyFilters() {
		let visible = 0;

		cards.forEach(card => {
			const dayMatch = !activeDay      || card.dataset.day      === activeDay;
			const locMatch = !activeLocation || card.dataset.location === activeLocation;
			card.style.display = dayMatch && locMatch ? '' : 'none';
			if (dayMatch && locMatch) visible++;
		});

		emptyState.style.display = visible === 0 ? '' : 'none';

		// Update active filter indicator
		const parts: string[] = [];
		if (activeDay)      parts.push(`📅 ${activeDay}`);
		if (activeLocation) parts.push(`📍 ${activeLocation}`);

		filterText.textContent      = parts.join(' · ');
		activeBar.style.display     = parts.length > 0 ? '' : 'none';
	}

	// ── Filter type toggle (Dag ↔ Område) ─────────────────────────────────────
	document.querySelectorAll<HTMLButtonElement>('.filter-pill[data-filter]').forEach(pill => {
		pill.addEventListener('click', () => {
			document.querySelectorAll('.filter-pill[data-filter]').forEach(p => p.classList.remove('active-filter'));
			pill.classList.add('active-filter');

			const isDag = pill.dataset.filter === 'dag';
			dagGroup.classList.toggle('hidden', !isDag);
			omradeGroup.classList.toggle('hidden', isDag);
		});
	});

	// ── Day pills ─────────────────────────────────────────────────────────────
	document.querySelectorAll<HTMLButtonElement>('.pill[data-day]').forEach(btn => {
		btn.addEventListener('click', () => {
			const day = btn.dataset.day!;
			const isActive = activeDay === day;

			activeDay = isActive ? null : day;
			document.querySelectorAll('.pill[data-day]').forEach(b => b.classList.remove('active'));
			if (!isActive) btn.classList.add('active');

			applyFilters();
		});
	});

	// ── Location pills ────────────────────────────────────────────────────────
	document.querySelectorAll<HTMLButtonElement>('.location-pill[data-location]').forEach(btn => {
		btn.addEventListener('click', () => {
			const loc = btn.dataset.location!;
			const isActive = activeLocation === loc;

			activeLocation = isActive ? null : loc;
			document.querySelectorAll('.location-pill[data-location]').forEach(b => b.classList.remove('active'));
			if (!isActive) btn.classList.add('active');

			applyFilters();
		});
	});

	// ── Clear all ─────────────────────────────────────────────────────────────
	clearBtn.addEventListener('click', () => {
		activeDay      = null;
		activeLocation = null;
		document.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
		applyFilters();
	});
</script>

<style>
	.calendar-section {
		background: var(--blue);
		padding: 40px 32px 60px;
	}
</style>
