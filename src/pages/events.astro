---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import EventCard from '../components/EventCard.astro';
import Footer from '../components/Footer.astro';

const eventsNav = [
	{ label: 'Kalenderen',   href: '/events',  variant: 'text'         as const },
	{ label: 'Om Headspace', href: '/om-os',   variant: 'text'         as const },
	{ label: 'Deltag',       href: '/deltag',  variant: 'pill-purple'  as const },
];

const days = ['Mandag', 'Tirsdag', 'Onsdag', 'Torsdag', 'Fredag', 'Lørdag'];
const activeDay = 'Onsdag';

type Campaign = 'det-okay' | 'diy' | 'brave-together';

const events: { title: string; time: string; location: string; campaign: Campaign }[] = [
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 15.00',  location: 'København',  campaign: 'det-okay'      },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 16.00',  location: 'Aarhus',     campaign: 'diy'           },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 17.30',  location: 'Odense',     campaign: 'brave-together'},
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 12.00',  location: 'Aalborg',    campaign: 'det-okay'      },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 14.00',  location: 'Roskilde',   campaign: 'diy'           },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 18.00',  location: 'Esbjerg',    campaign: 'brave-together'},
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 11.00',  location: 'Helsingør',  campaign: 'det-okay'      },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 13.00',  location: 'Vejle',      campaign: 'diy'           },
	{ title: 'Kampagne Titel', time: 'Onsdag kl. 19.00',  location: 'Fredericia', campaign: 'brave-together'},
];
---

<Layout>
	<Header navItems={eventsNav} />

	<!-- Hero -->
	<section class="hero">
		<div class="hero-text">
			<h1>Headspace<br/>Kalenderen</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="intro">
		<h2>EVENTS</h2>
		<p>
			Vi holder løbende events og kampagner for unge i hele Danmark. Kom med og vær en del af
			fællesskabet og hjælp os med at gøre en forskel.
		</p>
	</section>

	<!-- Filter + Calendar + Cards -->
	<section class="calendar-section">
		<div class="filter-bar">
			<div class="filter-group">
				<span class="filter-label">Filter</span>
				<div class="filters">
					<button class="filter-pill active-filter">Dag</button>
					<button class="filter-pill">Område</button>
				</div>
			</div>

			<div class="day-group">
				<span class="day-label">Kalender</span>
				<div class="days">
					{days.map((day) => (
						<button class:list={['day-pill', { 'day-active': day === activeDay }]}>
							{day}
						</button>
					))}
				</div>
			</div>
		</div>

		<div class="cards-grid">
			{events.map((event) => (
				<EventCard
					title={event.title}
					time={event.time}
					location={event.location}
					campaign={event.campaign}
					href={`/events/${event.campaign}`}
				/>
			))}
		</div>
	</section>

	<Footer />
</Layout>

<style>
	/* ── Hero ── */
	.hero {
		width: 100%;
		min-height: 320px;
		background: linear-gradient(160deg, #a8d88a 0%, #78BA53 50%, #4a7c32 100%);
		display: flex;
		align-items: flex-end;
		padding: 40px 32px;
	}

	.hero h1 {
		font-family: 'Gasoek One', sans-serif;
		font-size: clamp(2.5rem, 8vw, 5rem);
		font-weight: 400;
		line-height: 1;
		margin: 0;
		color: transparent;
		-webkit-text-stroke: 3px white;
		text-stroke: 3px white;
		letter-spacing: -0.01em;
	}

	/* ── Intro ── */
	.intro {
		background: var(--cream);
		padding: 52px 32px 40px;
		text-align: center;
	}

	.intro h2 {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 2rem;
		color: var(--purple);
		margin: 0 0 16px;
		letter-spacing: 0.02em;
	}

	.intro p {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text);
		max-width: 580px;
		margin: 0 auto;
	}

	/* ── Calendar section ── */
	.calendar-section {
		background: var(--blue);
		padding: 40px 32px 60px;
	}

	/* Filter bar */
	.filter-bar {
		max-width: 960px;
		margin: 0 auto 36px;
		display: flex;
		align-items: flex-start;
		gap: 40px;
		flex-wrap: wrap;
	}

	.filter-label,
	.day-label {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 1.1rem;
		color: var(--purple);
		display: block;
		margin-bottom: 10px;
	}

	.filters {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.filter-pill {
		padding: 8px 20px;
		border-radius: 999px;
		border: 2px solid var(--text);
		background: transparent;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--text);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
		text-align: left;
	}

	.filter-pill.active-filter,
	.filter-pill:hover {
		background: var(--text);
		color: white;
	}

	.day-group {
		flex: 1;
	}

	.days {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.day-pill {
		padding: 8px 18px;
		border-radius: 999px;
		border: 2px solid var(--green);
		background: transparent;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--green);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}

	.day-pill:hover {
		background: var(--green);
		color: white;
	}

	.day-active {
		background: var(--green) !important;
		color: white !important;
	}

	/* Cards grid */
	.cards-grid {
		max-width: 960px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}

	@media (max-width: 768px) {
		.cards-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.filter-bar {
			flex-direction: column;
			gap: 24px;
		}
	}

	@media (max-width: 480px) {
		.cards-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
