---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tilmelding — headspace Danmark">

	<!-- Loading state -->
	<div id="loading-state" class="loading-state">
		<p>Indlæser event…</p>
	</div>

	<!-- Error state -->
	<div id="error-state" class="error-state" style="display:none;">
		<h2>Event ikke fundet</h2>
		<p>Gå tilbage til <a href="/events">alle events</a>.</p>
	</div>

	<!-- Page content (hidden until JS populates it) -->
	<div id="page-content" style="display:none;">

		<!-- ── Hero ── -->
		<section class="hero">
			<h1 id="hero-title">Tilmelding</h1>
		</section>

		<!-- ── Event detail section ── -->
		<section class="event-section" id="event-section">
			<div class="event-inner">

				<!-- Campaign name + date -->
				<div class="event-header">
					<h1 id="campaign-name"></h1>
					<p id="event-date" class="event-date"></p>
				</div>

				<!-- Two columns: text left, poster grid right -->
				<div class="event-body">

					<div class="event-left">
						<p id="event-title" class="event-title"></p>
						<div id="event-description" class="event-description"></div>
						<div class="chips">
							<span class="chip" id="chip-time"></span>
							<span class="chip" id="chip-location"></span>
						</div>
					</div>

					<!-- Poster grid — CSS shows correct campaign via data-campaign attribute -->
					<div class="event-right">
						<div class="poster-display" id="poster-display" data-campaign="">

							<!-- DET OKAY -->
							<div class="poster-visual det-okay-visual">
								<div class="p-grid">
									{Array(4).fill(null).map(() => (
										<div class="p-panel det-okay-panel">
											<span class="p-tag">DET</span>
											<span class="p-tag">ER</span>
											<span class="p-tag p-accent">OKAY</span>
										</div>
									))}
								</div>
							</div>

							<!-- DIY -->
							<div class="poster-visual diy-visual">
								<div class="p-grid">
									{Array(4).fill(null).map(() => (
										<div class="p-panel diy-panel">
											<span class="diy-label">DIY</span>
											<span class="diy-sub">UNGDOMMEN<br/>EN STEMME</span>
										</div>
									))}
								</div>
							</div>

							<!-- BRAVE TOGETHER -->
							<div class="poster-visual brave-visual">
								<div class="p-grid">
									{Array(4).fill(null).map(() => (
										<div class="p-panel brave-panel">
											<div class="brave-top">MAYBELLINE x headspace</div>
											<div class="brave-main">BRAVE<br/>TOGETHER</div>
										</div>
									))}
								</div>
							</div>

						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- ── Sign-up section ── -->
		<section class="signup-section">
			<div class="signup-inner">
				<h2>DELTAG I EVENT</h2>
				<p class="signup-lead">
					Har du lyst til at være en del af et fællesskab, der løfter unge og står sammen om
					bedre trivsel? Tilmeld dig til en af vores kommende events gennem formularen og
					bliv en del af Headspace-fællesskabet.
				</p>
				<p class="signup-sub">
					Sammen skaber vi rum, hvor unge kan blive hørt, støttet og mødt — af hinanden.
				</p>

				<form class="form-card" id="signup-form">
					<div class="form-row">
						<label for="navn">Navn</label>
						<input type="text" id="navn" name="navn" required />
					</div>
					<div class="form-row">
						<label for="telefon">Telefon nummer</label>
						<input type="tel" id="telefon" name="telefon" required />
					</div>
					<div class="form-row">
						<label for="email">Gmail</label>
						<input type="email" id="email" name="email" required />
					</div>
					<button type="submit" class="submit-btn">Deltag i event &gt;</button>
				</form>

				<div id="success-msg" class="success-msg" style="display:none;">
					<p>🎉 Tak for din tilmelding! Vi glæder os til at se dig.</p>
				</div>
			</div>
		</section>

	</div>

</Layout>

<script>
	import { createClient } from '@supabase/supabase-js';

	// ── Supabase client (uses PUBLIC_ vars bundled by Astro at build time) ────
	const supabase = createClient(
		import.meta.env.PUBLIC_SUPABASE_URL,
		import.meta.env.PUBLIC_SUPABASE_KEY,
	);

	// ── Campaign helpers ──────────────────────────────────────────────────────
	const titleToCampaign: Record<string, string> = {
		'Gåtur':                    'det-okay',
		'Løb med Headspace':        'diy',
		'Foredrag med influencer':  'diy',
		'Brætspilscafe':            'brave-together',
		'Koncert med musiker':      'brave-together',
		'Headspace LAN event':      'diy',
		'Intimkoncert med musiker': 'brave-together',
	};

	const campaignDisplayName: Record<string, string> = {
		'det-okay':       'DET OKAY',
		'diy':            'DIY',
		'brave-together': 'BRAVE TOGETHER',
	};

	// ── Date formatters ───────────────────────────────────────────────────────
	function formatDanishDate(dateStr: string): string {
		const [year, month, day] = dateStr.split('-').map(Number);
		const date   = new Date(year, month - 1, day);
		const dayName = date.toLocaleDateString('da-DK', { weekday: 'long' });
		return `${dayName.charAt(0).toUpperCase() + dayName.slice(1)} den ${day}.${month}.${year}`;
	}

	function formatTime(timeStr: string): string {
		return 'kl. ' + timeStr.slice(0, 5).replace(':', '.');
	}

	// ── DOM helpers ───────────────────────────────────────────────────────────
	function show(id: string)  { (document.getElementById(id)!).style.display = ''; }
	function hide(id: string)  { (document.getElementById(id)!).style.display = 'none'; }
	function text(id: string, value: string) { document.getElementById(id)!.textContent = value; }

	// Render beskrivelse text — split newlines into paragraphs
	function renderDescription(raw: string) {
		const el = document.getElementById('event-description')!;
		el.innerHTML = raw
			.split('\n')
			.filter(line => line.trim())
			.map(line => `<p>${line}</p>`)
			.join('');
	}

	// ── Main: read URL param + fetch event ───────────────────────────────────
	const params   = new URLSearchParams(window.location.search);
	const eventId  = params.get('id');

	if (!eventId) {
		hide('loading-state');
		show('error-state');
	} else {
		const { data, error } = await supabase
			.from('headspace')
			.select('*')
			.eq('id', eventId)
			.single();

		hide('loading-state');

		if (error || !data) {
			show('error-state');
		} else {
			const campaign    = titleToCampaign[data.titel as string] ?? 'det-okay';
			const danishDate  = formatDanishDate(data.dato as string);
			const time        = formatTime(data.tid as string);

			// Populate text elements
			text('hero-title',    data.titel as string);
			text('campaign-name', campaignDisplayName[campaign]);
			text('event-date',    danishDate);
			text('event-title',   data.titel as string);
			renderDescription(data.beskrivelse as string);
			text('chip-time',     `Dag/Tid: ${danishDate} ${time}`);
			text('chip-location', `Lokation: ${data.sted as string}`);

			// Set campaign on poster display (CSS handles which poster is shown)
			document.getElementById('poster-display')!.dataset.campaign = campaign;

			// Set section background based on campaign
			document.getElementById('event-section')!.dataset.campaign = campaign;

			show('page-content');
		}
	}

	// ── Form submit ───────────────────────────────────────────────────────────
	document.getElementById('signup-form')!.addEventListener('submit', (e) => {
		e.preventDefault();
		hide('signup-form');
		show('success-msg');
	});
</script>

<style>
	/* ── Loading / error states ── */
	.loading-state,
	.error-state {
		min-height: 40vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		font-family: 'Agrandir', sans-serif;
		font-size: 1.1rem;
		color: var(--purple);
		gap: 12px;
	}

	.error-state h2 {
		font-weight: 900;
		font-size: 1.8rem;
		margin: 0;
	}

	.error-state a {
		color: var(--green);
		text-decoration: underline;
	}

	/* ── Hero ── */
	.hero {
		width: 100%;
		min-height: 280px;
		background: linear-gradient(160deg, #a8d88a 0%, #78BA53 50%, #4a7c32 100%);
		display: flex;
		align-items: flex-end;
		padding: 40px 32px;
	}

	.hero h1 {
		font-family: 'Gasoek One', sans-serif;
		font-size: clamp(2.5rem, 8vw, 5rem);
		font-weight: 400;
		line-height: 1;
		margin: 0;
		color: transparent;
		-webkit-text-stroke: 3px white;
		letter-spacing: -0.01em;
	}

	/* ── Event section ── */
	.event-section {
		background: var(--blue);
		padding: 52px 32px 48px;
	}

	/* Campaign-specific bright backgrounds */
	.event-section[data-campaign="det-okay"]       { background: var(--blue); }
	.event-section[data-campaign="diy"]             { background: #d4f0bc; }
	.event-section[data-campaign="brave-together"]  { background: var(--lavender); }

	.event-inner {
		max-width: 960px;
		margin: 0 auto;
	}

	/* Header */
	.event-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.event-header h1 {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: clamp(2rem, 6vw, 3.5rem);
		color: var(--purple);
		margin: 0 0 8px;
		letter-spacing: 0.02em;
	}

	.event-date {
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 1rem;
		color: var(--text);
		margin: 0;
	}

	/* Two-column body */
	.event-body {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 40px;
		align-items: start;
	}

	/* Left: text */
	.event-title {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 1.1rem;
		color: var(--green);
		margin-bottom: 16px;
	}

	.event-description p {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--text);
		margin: 0 0 14px;
	}

	.chips {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin-top: 24px;
	}

	.chip {
		display: inline-block;
		padding: 8px 16px;
		border-radius: 8px;
		background: rgba(255,255,255,0.6);
		border: 1.5px solid var(--green);
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.82rem;
		color: var(--text);
		align-self: flex-start;
	}

	/* Right: poster grid */
	.poster-display { width: 100%; }

	/* Hide all visuals by default; show based on data-campaign */
	.poster-visual { display: none; }

	.poster-display[data-campaign="det-okay"]       .det-okay-visual { display: block; }
	.poster-display[data-campaign="diy"]             .diy-visual      { display: block; }
	.poster-display[data-campaign="brave-together"]  .brave-visual    { display: block; }

	/* 2×2 poster grid */
	.p-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: 1fr 1fr;
		gap: 6px;
		border-radius: 14px;
		overflow: hidden;
		aspect-ratio: 1;
	}

	.p-panel {
		display: flex;
		flex-direction: column;
		padding: 14px;
	}

	/* DET OKAY panels */
	.det-okay-panel { background: #1c1c1c; justify-content: flex-end; gap: 1px; }

	.p-tag {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 1.1rem;
		color: #e8e8e8;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.p-accent { color: #f5c4d0; }

	/* DIY panels */
	.diy-panel { background: #4a7c32; justify-content: center; gap: 6px; }

	.diy-label {
		font-family: 'Gasoek One', sans-serif;
		font-size: 2rem;
		color: white;
		line-height: 1;
	}

	.diy-sub {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 0.6rem;
		color: rgba(255,255,255,0.85);
		letter-spacing: 0.08em;
		line-height: 1.4;
	}

	/* BRAVE TOGETHER panels */
	.brave-panel { background: #1a3a5c; justify-content: space-between; padding: 0; }

	.brave-top {
		background: #c0392b;
		color: white;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.5rem;
		letter-spacing: 0.1em;
		padding: 6px 14px;
	}

	.brave-main {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 1rem;
		color: white;
		line-height: 1;
		padding: 0 14px 14px;
		align-self: flex-end;
	}

	/* ── Sign-up section ── */
	.signup-section {
		background: var(--cream);
		padding: 60px 32px;
	}

	.signup-inner {
		max-width: 600px;
		margin: 0 auto;
		text-align: center;
	}

	.signup-inner h2 {
		font-family: 'Agrandir', sans-serif;
		font-weight: 900;
		font-size: 2rem;
		color: var(--green);
		margin: 0 0 20px;
		letter-spacing: 0.02em;
	}

	.signup-lead {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--text);
		margin: 0 0 12px;
	}

	.signup-sub {
		font-family: 'Agrandir', sans-serif;
		font-weight: 400;
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--text);
		margin: 0 0 36px;
	}

	/* Form card */
	.form-card {
		background: white;
		border: 2px solid var(--text);
		border-radius: 16px;
		padding: 32px 36px;
		text-align: left;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.form-row {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.form-row label {
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.9rem;
		color: var(--text);
		min-width: 110px;
		flex-shrink: 0;
	}

	.form-row input {
		flex: 1;
		border: 1.5px solid #ccc;
		border-radius: 6px;
		padding: 8px 12px;
		font-family: 'Agrandir', sans-serif;
		font-size: 0.9rem;
		color: var(--text);
		outline: none;
		transition: border-color 0.15s;
	}

	.form-row input:focus {
		border-color: var(--purple);
	}

	.submit-btn {
		align-self: center;
		margin-top: 8px;
		padding: 12px 32px;
		border-radius: 999px;
		border: none;
		background: var(--purple);
		color: white;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 0.95rem;
		cursor: pointer;
		transition: opacity 0.2s;
	}

	.submit-btn:hover { opacity: 0.85; }

	/* Success message */
	.success-msg {
		margin-top: 32px;
		padding: 24px;
		background: #eafbe4;
		border-radius: 12px;
		font-family: 'Agrandir', sans-serif;
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--green);
	}

	/* ── Responsive ── */
	@media (max-width: 680px) {
		.event-body {
			grid-template-columns: 1fr;
		}

		.event-right {
			order: -1;
			max-width: 340px;
			margin: 0 auto;
			width: 100%;
		}

		.form-row {
			flex-direction: column;
			align-items: flex-start;
			gap: 6px;
		}

		.form-row input { width: 100%; }
	}
</style>
